# Postgres connection string for shareable links.
# Required for: POST /api/share, /v/[id] viewer page.
DATABASE_URL=postgres://user:password@host:5432/binderly

# SSL mode for the connection. Defaults to "prefer".
# Set to "false" for local self-hosted Postgres without SSL.
# Set to "require" for managed providers that require SSL.
# DATABASE_SSL=false

# Optional: opt-in analytics. Leave UNSET for self-hosted instances —
# nothing will be loaded. Set on your own hosted deployment only.
# NEXT_PUBLIC_RYBBIT_SITE_ID is the only required value to enable tracking.
# NEXT_PUBLIC_RYBBIT_SITE_ID=your-site-id
# NEXT_PUBLIC_RYBBIT_SRC=https://rybbit.example.com/api/script.js
